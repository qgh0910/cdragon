# ============================================
# DashScope API 配置示例
# ============================================
# 
# 使用方法：
# 1. 复制此文件为 .env
# 2. 填入你的实际配置值
# 3. 或者在 PyCharm 中直接配置环境变量
#
# PyCharm 配置方法：
# 1. 打开 Run -> Edit Configurations
# 2. 选择你的运行配置（或创建新配置）
# 3. 找到 Environment variables 选项
# 4. 点击右侧的文件夹图标
# 5. 添加下面的环境变量（去掉注释符号#）
# 6. 点击 OK 保存
#
# ============================================

# DashScope API 密钥（必填）
# 访问地址获取： https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=

# DashScope API 基础 URL（可选，默认值如下）
# 官方 API 地址
DASHSCOPE_BASE_URL=

# 默认模型名称（可选）
# 可选模型列表： https://help.aliyun.com/zh/model-studio/getting-started/models
# 常用模型：qwen-plus、qwen-max、deepseek-v3 等
DASHSCOPE_MODEL=deepseek-v4-flash

# ============================================
# Agent 配置
# ============================================

# Agent 最大迭代次数
AGENT_MAX_ITERATIONS=10

# 是否输出详细日志（true/false）
AGENT_VERBOSE=true

# ============================================
# 请求配置
# ============================================

# 请求超时时间（秒）
REQUEST_TIMEOUT=60

# 最大重试次数
MAX_RETRIES=3

# ============================================
# 认证与会话配置
# ============================================

# 认证签名密钥（生产环境必填；请在本地 .env 中设置真实随机值）
AUTH_SECRET_KEY=

# 首次启动时自动创建管理员（未配置则不自动创建）
INITIAL_ADMIN_USERNAME=admin

# 首次启动管理员密码（只在本地 .env 或运行环境变量中填写真实值）
INITIAL_ADMIN_PASSWORD=admin123

# Session 有效期（小时）
SESSION_EXPIRE_HOURS=24

# 生产 HTTPS 环境建议设为 true
AUTH_COOKIE_SECURE=false

# 允许携带认证 Cookie 的前端来源，多个来源用英文逗号分隔
AUTH_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# 是否允许服务器路径导入能力（普通部署建议 false）
AUTH_ENABLE_SERVER_PATH_IMPORT=false

# 每分钟允许的登录尝试次数
AUTH_LOGIN_RATE_LIMIT_PER_MINUTE=5

# ============================================
# LPOS 合同结构化解析配置
# ============================================

# 单份合同结构化解析的最大字符数
LPOS_CONTRACT_PARSE_MAX_CHARS=200000

# 单份合同最多返回的条款数量
LPOS_CONTRACT_PARSE_MAX_CLAUSES=300

# 单条合同条款预览的最大字符数
LPOS_CONTRACT_PARSE_CLAUSE_PREVIEW_CHARS=1200

# 来源定位文本预览的最大字符数
LPOS_CONTRACT_PARSE_SOURCE_PREVIEW_CHARS=160

# 是否启用 LLM 辅助结构化抽取（默认关闭）
LPOS_CONTRACT_PARSE_USE_LLM=false

# LLM 辅助结构化抽取超时时间（秒）
LPOS_CONTRACT_PARSE_LLM_TIMEOUT=60

# 安全提示：
# - 不要提交真实密码、真实 AUTH_SECRET_KEY 或真实 DASHSCOPE_API_KEY。
# - 本地启动可运行 python run_web.py。
# - 启动后可访问 /api/health 检查服务状态。

# ============================================
# 故障转移配置
# ============================================

# 是否启用故障转移（true/false）
ENABLE_FAILOVER=true

# ============================================
# RAG（检索增强生成）配置
# ============================================

# 向量数据库存储路径（可选，默认：./data/chroma）
# CHROMA_PERSIST_DIRECTORY=./data/chroma

# 是否使用云端嵌入服务（推荐：true，启动更快）
USE_CLOUD_EMBEDDING=true

# 云端嵌入模型（当 USE_CLOUD_EMBEDDING=true 时使用）
CLOUD_EMBEDDING_MODEL=text-embedding-v4
# embedding设置
CHUNK_SIZE=300
CHUNK_OVERLAP=40
RETRIEVAL_TOP_K=4
RERANK_TOP_K=3
MAX_CONTEXT_TOKENS=3000

# 是否使用云端重排序服务（推荐：true）
USE_CLOUD_RERANKER=true

# 云端重排序 API 基础 URL（qwen3-rerank 使用 compatible-api）
CLOUD_RERANKER_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1

# 云端重排序模型（当 USE_CLOUD_RERANKER=true 时使用）
CLOUD_RERANKER_MODEL=qwen3-rerank

# ============================================
# 模型分配配置（高级）
# ============================================

# Agent 专用模型（留空则使用主对话模型）
# AGENT_MODEL=GLM-4-Flash

# 查询优化模型（留空则使用主对话模型）
# QUERY_OPTIMIZER_MODEL=Qwen2.5-14B-Instruct
